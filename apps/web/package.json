{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:open-next": "open-next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env.local db/migrate.ts",
    "db:seed": "tsx --env-file=.env.local db/seed.ts",
    "db:seed:demo": "tsx db/seed-demo.ts",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:coverage": "node test-lib/spec-test/dist/cli.js --spec specs/armoury.yml --coverage .spec-coverage/results.jsonl --out spec-coverage.md",
    "test:coverage:loose": "node test-lib/spec-test/dist/cli.js --spec specs/armoury.yml --coverage .spec-coverage/results.jsonl --out spec-coverage.md --no-strict",
    "test:spec": "npm run test:unit && npm run test:e2e && npm run test:coverage"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@hookform/resolvers": "^5.4.0",
    "@opennextjs/aws": "^4.0.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.0.0",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/ratelimit": "^2.0.0",
    "@upstash/redis": "^1.34.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "posthog-js": "^1.180.0",
    "posthog-node": "^4.10.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.1",
    "recharts": "^3.8.0",
    "resend": "^4.0.0",
    "sonner": "^1.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^6",
    "vitest": "^4.1.7"
  }
}
